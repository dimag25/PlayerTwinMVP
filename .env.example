# Player Twin local preview configuration.
# Do not put real secrets in this file.

APP_ENV=preview
NODE_ENV=production
PORT=8888
APP_BASE_URL=http://127.0.0.1:8888
PUBLIC_WEB_ORIGIN=http://127.0.0.1:8888
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8888

# Preview mode may use demo auth and JSON storage for internal UI/QA review only.
AUTH_PROVIDER=demo
DATA_ADAPTER=json
MEDIA_SCOPE=demo_all

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=600
BODY_LIMIT_JSON_BYTES=65536
ENABLE_HSTS=false
RELEASE_SHA=local

# Strict staging placeholders. Use APP_ENV=staging only after these are real.
# AUTH_PROVIDER=auth0
# AUTH_ISSUER=https://example.eu.auth0.com/
# AUTH_AUDIENCE=https://api.staging.player-twin.example
# AUTH_JWKS_URL=https://example.eu.auth0.com/.well-known/jwks.json
# DATA_ADAPTER=postgres
# DATABASE_URL=replace-with-postgresql-url
# DATABASE_SSL_MODE=require
# ALLOW_SYNTHETIC_SEED=false

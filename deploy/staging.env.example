APP_ENV=staging
NODE_ENV=production
PORT=8888

AUTH_PROVIDER=auth0
AUTH_ISSUER=https://replace-me.eu.auth0.com/
AUTH_AUDIENCE=https://api.staging.player-twin.example
AUTH_JWKS_URL=https://replace-me.eu.auth0.com/.well-known/jwks.json

DATA_ADAPTER=postgres
DATABASE_URL=replace-with-postgresql-url
DATABASE_SSL_MODE=require

MEDIA_SCOPE=profile_images
APP_BASE_URL=https://staging.player-twin.example
PUBLIC_WEB_ORIGIN=https://staging.player-twin.example
CORS_ALLOWED_ORIGINS=https://staging.player-twin.example

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
BODY_LIMIT_JSON_BYTES=65536
ENABLE_HSTS=true
RELEASE_SHA=replace-with-git-sha
ALLOW_SYNTHETIC_SEED=false

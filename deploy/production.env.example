APP_ENV=production
NODE_ENV=production
PORT=8888

AUTH_PROVIDER=auth0
AUTH_ISSUER=replace-with-production-auth0-issuer
AUTH_AUDIENCE=replace-with-production-api-audience
AUTH_JWKS_URL=replace-with-production-auth0-jwks-url

DATA_ADAPTER=postgres
DATABASE_URL=replace-with-production-postgresql-url
DATABASE_SSL_MODE=require

MEDIA_SCOPE=profile_images
APP_BASE_URL=replace-with-production-https-url
PUBLIC_WEB_ORIGIN=replace-with-production-https-url
CORS_ALLOWED_ORIGINS=replace-with-production-https-url

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
BODY_LIMIT_JSON_BYTES=65536
ENABLE_HSTS=true
RELEASE_SHA=replace-with-git-sha
ALLOW_SYNTHETIC_SEED=false

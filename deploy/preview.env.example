APP_ENV=preview
NODE_ENV=production
PORT=8888
AUTH_PROVIDER=demo
DATA_ADAPTER=json
MEDIA_SCOPE=demo_all
APP_BASE_URL=https://preview.example.invalid
PUBLIC_WEB_ORIGIN=https://preview.example.invalid
CORS_ALLOWED_ORIGINS=https://preview.example.invalid
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=600
BODY_LIMIT_JSON_BYTES=65536
ENABLE_HSTS=true
RELEASE_SHA=replace-with-git-sha
